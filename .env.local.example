# ============================================================
# 猎英盟 AI 猎头助手 - 环境变量配置
# 复制为 .env.local 后填入真实值
# ============================================================

# Supabase（必填）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI 服务（二选一，优先 SiliconFlow）
# 硅基流动（推荐国内用户，中文优化，成本低）
SILICONFLOW_API_KEY=sk-your-siliconflow-api-key
SILICONFLOW_MODEL=Qwen/Qwen2.5-72B-Instruct

# OpenAI（可选，海外或已配置代理时使用）
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=gpt-4o

# IMA 知识库（可选，用于 AI 持续学习）
# IMA_API_KEY=your-ima-api-key
# IMA_APP_ID=your-ima-app-id

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# Phase 1 部署步骤
# ============================================================
# 1. 在 Supabase SQL Editor 执行: scripts/migration_pgvector.sql
# 2. npm install && npm run embed:jobs   # 批量生成职位 embedding
# 3. npm run dev                         # 启动开发服务器
# ============================================================
